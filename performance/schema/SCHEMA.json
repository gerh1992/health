{
  "file_type": "performance_log",
  "canonical_csv_path": "/home/ubuntu/.hermes/data/health/performance/data/performance_log.csv",
  "backup_dir": "/home/ubuntu/.hermes/data/health/performance/backups",
  "timezone": "America/Argentina/Mendoza",
  "late_night_attribution": {
    "local_window_start": "00:00",
    "local_window_end": "03:59",
    "default_assign_to_previous_waking_day": true
  },
  "columns": [
    {
      "name": "Date",
      "type": "date",
      "format": "YYYY-MM-DD",
      "required": true
    },
    {
      "name": "Category",
      "type": "enum",
      "required": true,
      "allowed": [
        "Biometrics",
        "Strength",
        "Padel",
        "Recovery",
        "Social",
        "Work"
      ]
    },
    {
      "name": "Activity",
      "type": "string",
      "required": true
    },
    {
      "name": "Entry_Type",
      "type": "enum",
      "required": true,
      "allowed": [
        "biometrics",
        "session",
        "kpi",
        "accessory"
      ]
    },
    {
      "name": "Session_Tag",
      "type": "enum",
      "required": true,
      "allowed": [
        "High",
        "Low",
        "Match",
        "Technical",
        "Recovery",
        "Social",
        "Work",
        "-"
      ]
    },
    {
      "name": "Volume_Detail",
      "type": "string",
      "required": true
    },
    {
      "name": "RPE",
      "type": "string",
      "required": true,
      "notes": "Use '-' when unknown"
    },
    {
      "name": "HRV_Morning",
      "type": "string",
      "required": true,
      "notes": "Integer-as-string or '-'"
    },
    {
      "name": "RHR_Night",
      "type": "string",
      "required": true,
      "notes": "Integer-as-string or '-'"
    },
    {
      "name": "Comments",
      "type": "string",
      "required": true
    }
  ],
  "volume_detail_rules": {
    "Biometrics": {
      "biometrics": {
        "pattern": "^\\d+(?:\\.\\d+)?$",
        "notes": "Represents sleep hours as a decimal number (e.g. 7.5, 8.0, 6.8)"
      }
    },
    "Strength": {
      "kpi": {
        "pattern": "^\\d+(?:\\.\\d+)?kg\\s+(?:-\\s+\\d+x\\d+|x\\d+\\s+top set)(?:;\\s+\\d+(?:\\.\\d+)?kg\\s+(?:-\\s+\\d+x\\d+|x\\d+\\s+top set))*$",
        "notes": "Format for principal lifts. Examples: '90kg - 3x4', '110kg x3 top set; 100kg - 2x4'"
      },
      "accessory": {
        "pattern": "^\\d+(?:\\.\\d+)?kg\\s+-\\s+\\d+x\\d+(?:;\\s+\\d+(?:\\.\\d+)?kg\\s+-\\s+\\d+x\\d+)*$",
        "notes": "Format for accessories. Example: '100kg - 3x10'"
      },
      "session": {
        "pattern": "^.*$",
        "notes": "Free-text summary of the gym session"
      }
    },
    "Padel": {
      "session": {
        "pattern": "^(?:Win|Loss|-)\\s+\\|\\s+\\d+h(?:\\s+\\d+m)?$",
        "notes": "Format for padel matches. Examples: 'Win | 1h 30m', 'Loss | 1h 30m', '- | 1h'"
      }
    }
  }
}
